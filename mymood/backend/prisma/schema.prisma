generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model albums {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title           String
  artist_id       String?   @db.Uuid
  cover_image_url String?
  release_date    DateTime? @db.Date
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  artists         artists?  @relation(fields: [artist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  songs           songs[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model artists {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String    @unique
  profile_image_url String?
  bio               String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  albums            albums[]
  songs             songs[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model friendships {
  user_id                            String    @db.Uuid
  friend_id                          String    @db.Uuid
  status                             String    @default("pending") @db.VarChar(20)
  created_at                         DateTime? @default(now()) @db.Timestamptz(6)
  users_friendships_friend_idTousers users     @relation("friendships_friend_idTousers", fields: [friend_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_friendships_user_idTousers   users     @relation("friendships_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, friend_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model liked_songs {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  song_id    String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  songs      songs?    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, song_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id                                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                              String   @db.Uuid
  sender_id                            String?  @db.Uuid
  title                                String
  message                              String
  type                                 String
  is_read                              Boolean? @default(false)
  created_at                           DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_notifications_sender_idTousers users?   @relation("notifications_sender_idTousers", fields: [sender_id], references: [id], onUpdate: NoAction)
  users_notifications_user_idTousers   users    @relation("notifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model play_history {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?   @db.Uuid
  song_id     String?   @db.Uuid
  played_at   DateTime? @default(now()) @db.Timestamptz(6)
  songs       songs?    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model playlist_tracks {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playlist_id String?    @db.Uuid
  song_id     String?    @db.Uuid
  order_index Int
  added_at    DateTime?  @default(now()) @db.Timestamptz(6)
  playlists   playlists? @relation(fields: [playlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  songs       songs?     @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model playlists {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @db.VarChar(100)
  user_id         String?           @db.Uuid
  is_public       Boolean?          @default(false)
  is_ai_generated Boolean?          @default(false)
  ai_prompt_used  String?
  cover_image_url String?
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  description     String?
  playlist_tracks playlist_tracks[]
  users           users?            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model shared_inbox {
  id                                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                             String?   @db.Uuid
  receiver_id                           String?   @db.Uuid
  song_id                               String?   @db.Uuid
  message                               String?
  status                                String?   @default("unread") @db.VarChar(20)
  created_at                            DateTime? @default(now()) @db.Timestamptz(6)
  users_shared_inbox_receiver_idTousers users?    @relation("shared_inbox_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_shared_inbox_sender_idTousers   users?    @relation("shared_inbox_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  songs                                 songs?    @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model song_vectors {
  song_id       String                 @id @db.Uuid
  mood_keywords String?
  embedding     Unsupported("vector")?
  updated_at    DateTime?              @default(now()) @db.Timestamptz(6)
  songs         songs                  @relation(fields: [song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model songs {
  id                                         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                                      String            @db.VarChar(255)
  artist                                     String            @db.VarChar(255)
  cover_image_url                            String?
  audio_file_url                             String
  duration_seconds                           Int?
  uploaded_by                                String?           @db.Uuid
  is_public                                  Boolean?          @default(true)
  created_at                                 DateTime?         @default(now()) @db.Timestamptz(6)
  danceability                               Float?            @db.Real
  bpm                                        Float?            @db.Real
  music_key                                  String?
  energy                                     Float?            @db.Real
  music_scale                                String?
  play_count                                 Int?              @default(0)
  artist_id                                  String?           @db.Uuid
  genre                                      String?
  album_id                                   String?           @db.Uuid
  liked_songs                                liked_songs[]
  play_history                               play_history[]
  playlist_tracks                            playlist_tracks[]
  shared_inbox                               shared_inbox[]
  song_vectors                               song_vectors?
  albums                                     albums?           @relation(fields: [album_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  artists                                    artists?          @relation(fields: [artist_id], references: [id], onUpdate: NoAction)
  users_songs_uploaded_byTousers             users?            @relation("songs_uploaded_byTousers", fields: [uploaded_by], references: [id], onUpdate: NoAction)
  users_users_profile_song_idTosongs users[]           @relation("users_profile_song_idTosongs")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  handle                                       String          @unique @db.VarChar(30)
  username                                     String          @unique @db.VarChar(50)
  email                                        String          @unique @db.VarChar(100)
  password_hash                                String          @db.VarChar(255)
  profile_image_url                            String?
  profile_song_id                              String?         @db.Uuid
  last_active                                  DateTime?       @default(now()) @db.Timestamptz(6)
  created_at                                   DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                                   DateTime?       @default(now()) @db.Timestamptz(6)
  is_online                                    Boolean?        @default(false)
  current_playing_song_id                      String?
  role                                         String?         @default("user")
  bio                                          String?
  link                                         String?
  banner_image_url                             String?
  show_activity_status                         Boolean?  @default(true)
  show_uploads                                 Boolean?  @default(false)
  friendships_friendships_friend_idTousers     friendships[]   @relation("friendships_friend_idTousers")
  friendships_friendships_user_idTousers       friendships[]   @relation("friendships_user_idTousers")
  liked_songs                                  liked_songs[]
  notifications_notifications_sender_idTousers notifications[] @relation("notifications_sender_idTousers")
  notifications_notifications_user_idTousers   notifications[] @relation("notifications_user_idTousers")
  play_history                                 play_history[]
  playlists                                    playlists[]
  shared_inbox_shared_inbox_receiver_idTousers shared_inbox[]  @relation("shared_inbox_receiver_idTousers")
  shared_inbox_shared_inbox_sender_idTousers   shared_inbox[]  @relation("shared_inbox_sender_idTousers")
  songs_songs_uploaded_byTousers               songs[]         @relation("songs_uploaded_byTousers")
  songs_users_profile_song_idTosongs           songs?          @relation("users_profile_song_idTosongs", fields: [profile_song_id], references: [id], onUpdate: NoAction, map: "fk_profile_song")

  @@index([handle], map: "idx_users_handle")
}
